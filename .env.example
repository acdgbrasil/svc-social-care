# Server
PORT=3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=social_care

# Zitadel (Token Introspection — optional, for service accounts without role claims)
# ZITADEL_ISSUER=https://auth.acdgbrasil.com.br
# ZITADEL_INTROSPECT_CLIENT_ID=<API app client_id>
# ZITADEL_INTROSPECT_CLIENT_SECRET=<API app client_secret>
# ALLOWED_SERVICE_ACCOUNTS=<comma-separated user IDs from Zitadel>
